{
  "devDependencies": {
    "markdownlint-cli2": "^0.22.0",
    "prettier": "^3.8.1",
    "textlint": "^15.5.2",
    "textlint-rule-preset-ja-spacing": "^2.4.3",
    "textlint-rule-preset-ja-technical-writing": "^12.0.2",
    "vitepress": "^1.6.4"
  },
  "packageManager": "pnpm@10.32.1",
  "private": true,
  "scripts": {
    "docs:build": "vitepress build docs",
    "docs:dev": "vitepress dev docs",
    "docs:preview": "vitepress preview docs",
    "lint": "pnpm run textlint && pnpm run markdownlint && pnpm run prettier:check",
    "lint:fix": "pnpm run textlint:fix && pnpm run markdownlint:fix && pnpm run prettier:fix",
    "markdownlint": "markdownlint-cli2 docs/*.md README.md",
    "markdownlint:fix": "markdownlint-cli2 --fix docs/*.md README.md",
    "prettier:check": "prettier --check \"**/*.{yml,yaml,json}\"",
    "prettier:fix": "prettier --write \"**/*.{yml,yaml,json}\"",
    "textlint": "textlint docs/*.md README.md",
    "textlint:fix": "textlint --fix docs/*.md README.md"
  },
  "type": "module"
}
